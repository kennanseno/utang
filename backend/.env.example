# Backend environment (copy to .env or export before running)
# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/utang
DB_USER=utang
DB_PASSWORD=utang

# Public base URL used to build customer pay-page links in reminder messages
PUBLIC_BASE_URL=http://localhost:3000

# Resend email (account verification codes). Leave blank to log codes to the
# console instead of sending them. Get an API key at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Utang <no-reply@yourdomain.com>

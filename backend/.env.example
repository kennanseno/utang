# Backend environment (copy to .env or export before running)
# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/utang
DB_USER=utang
DB_PASSWORD=utang

# Public base URL used to build customer payment links in reminder messages
PUBLIC_BASE_URL=http://localhost:3000

# PayMongo — leave blank to use the built-in MOCK gateway (no external calls)
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=whsk_test_local
PAYMONGO_BASE_URL=https://api.paymongo.com/v1
